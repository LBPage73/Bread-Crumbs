#include <Servo.h>

Servo servo1;
Servo servo2;

int button1 = 2;
int button2 = 4;

void setup() {
  servo1.attach(9);
  servo2.attach(10);

  pinMode(button1, INPUT_PULLUP);
  pinMode(button2, INPUT_PULLUP);
}

void loop() {
  int state1 = digitalRead(button1);
  int state2 = digitalRead(button2);

  // Servo 1 (button on pin 2)
  if (state1 == LOW) {
    servo1.write(90);
  } else {
    servo1.write(0);
  }

  // Servo 2 (button on pin 4)
  if (state2 == LOW) {
    servo2.write(90);
  } else {
    servo2.write(0);
  }
}
